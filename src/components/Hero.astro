---
import { site } from "@/data/site";
const DISCORD_ID = "249879411594100751";
---

<section class="relative min-h-[85vh] flex flex-col items-center justify-center px-6 overflow-hidden">
  <!-- Glow orbs -->
  <div id="hero-glow-1" class="glow-orb w-[500px] h-[500px] bg-brand/15 top-[-10%] left-[-10%]" style="animation-delay: 0s;"></div>
  <div id="hero-glow-2" class="glow-orb w-[400px] h-[400px] bg-secondary/10 bottom-[-5%] right-[-8%]" style="animation-delay: 2s;"></div>

  <!-- Content -->
  <div class="relative z-10 text-center max-w-3xl">
    <!-- Avatar + hover activity wrapper -->
    <div class="mb-16 animate-bounce-in relative inline-block group">
      <div class="relative cursor-default">
        <img
          id="hero-avatar"
          src={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/images/icon.png`}
          alt="Kaan"
          class="w-28 h-28 rounded-full border-2 border-border mx-auto shadow-[0_0_40px_var(--color-brand-glow)] object-cover transition-all duration-500 group-hover:scale-105 opacity-0"
          onload="this.style.opacity='1'"
        />
        <span
          id="hero-status"
          class="absolute bottom-1 right-1 w-5 h-5 rounded-full border-[3px] border-bg hidden"
        ></span>
      </div>

      <!-- Activity pill — revealed on hover -->
      <div
        id="hero-activity"
        class="absolute top-full left-1/2 -translate-x-1/2 mt-3 opacity-0 scale-95 pointer-events-none group-hover:opacity-100 group-hover:scale-100 transition-all duration-300 z-20 hidden"
      >
        <div class="flex items-center gap-2.5 bg-bg-card border border-border rounded-full px-4 py-2 shadow-[0_8px_32px_var(--color-brand-glow)] whitespace-nowrap">
          <span id="hero-activity-emoji" class="text-base"></span>
          <div class="text-left">
            <p id="hero-activity-name" class="text-sm font-semibold text-text leading-tight"></p>
            <p id="hero-activity-detail" class="text-[11px] text-text-muted leading-tight"></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Name -->
    <h1 class="text-5xl sm:text-7xl font-heading font-bold mb-4 animate-fade-in-up">
      <span id="hero-name" class="transition-colors duration-700">{site.name}</span>
    </h1>

    <!-- Typing line -->
    <div class="h-8 mb-6 animate-fade-in" style="animation-delay: 0.2s;">
      <span class="font-mono text-text-muted text-lg">&gt;&nbsp;</span>
      <span id="typing-text" class="font-mono text-text-muted text-lg"></span>
      <span class="inline-block w-[2px] h-5 bg-brand ml-0.5 align-middle" style="animation: blink-caret 1s step-end infinite;"></span>
    </div>

    <!-- Tagline -->
    <p class="text-text-muted text-base sm:text-lg mb-10 max-w-lg mx-auto animate-fade-in" style="animation-delay: 0.35s;">
      {site.tagline}
    </p>

    <!-- Contact button -->
    <div class="animate-fade-in" style="animation-delay: 0.5s;">
      <button
        id="contact-btn"
        class="px-6 py-3 rounded-full border border-border text-text-muted font-semibold text-sm hover:border-border-hover hover:text-text hover:scale-105 transition-all duration-300 cursor-pointer"
      >
        contact
      </button>
    </div>
  </div>

  <!-- Contact modal -->
  <div id="contact-modal" class="fixed inset-0 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300">
    <div id="contact-overlay" class="absolute inset-0 bg-black/60 backdrop-blur-lg"></div>
    <div class="relative bg-bg-card/95 backdrop-blur-2xl border border-border rounded-3xl px-10 py-10 w-[360px] shadow-[0_24px_80px_rgba(0,0,0,0.5)] scale-90 transition-all duration-300" id="contact-panel">
      <button id="contact-close" class="absolute top-5 right-6 text-text-muted/25 hover:text-text-muted text-xl transition-colors duration-200 cursor-pointer">×</button>
      <p class="font-heading font-bold text-2xl text-text mb-2">get in touch</p>
      <p class="text-sm text-text-muted/60 mb-8">pick your preferred way</p>
      <div class="space-y-2">
        <a href={`mailto:${site.email}`} class="group flex items-center gap-4 px-5 py-4 rounded-2xl border border-border/50 hover:border-brand/40 hover:bg-brand/5 transition-all duration-300">
          <span class="w-12 h-12 rounded-xl bg-brand/10 group-hover:bg-brand/20 flex items-center justify-center transition-colors duration-300">
            <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
          </span>
          <div>
            <p class="text-sm font-semibold text-text group-hover:text-brand transition-colors duration-300">email</p>
            <p class="text-xs text-text-muted/50 mt-0.5">{site.email}</p>
          </div>
          <span class="ml-auto text-text-muted/20 group-hover:text-brand/60 group-hover:translate-x-1 transition-all duration-300 text-sm">→</span>
        </a>
        <a href="https://discord.com/users/249879411594100751" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-4 px-5 py-4 rounded-2xl border border-border/50 hover:border-[#5865F2]/40 hover:bg-[#5865F2]/5 transition-all duration-300">
          <span class="w-12 h-12 rounded-xl bg-[#5865F2]/10 group-hover:bg-[#5865F2]/20 flex items-center justify-center transition-colors duration-300">
            <svg class="w-5 h-5 text-[#5865F2]" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/></svg>
          </span>
          <div>
            <p class="text-sm font-semibold text-text group-hover:text-[#5865F2] transition-colors duration-300">discord</p>
            <p class="text-xs text-text-muted/50 mt-0.5">dm me anytime</p>
          </div>
          <span class="ml-auto text-text-muted/20 group-hover:text-[#5865F2]/60 group-hover:translate-x-1 transition-all duration-300 text-sm">→</span>
        </a>
        <a href="https://x.com/kaanreal" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-4 px-5 py-4 rounded-2xl border border-border/50 hover:border-text/40 hover:bg-text/5 transition-all duration-300">
          <span class="w-12 h-12 rounded-xl bg-text/5 group-hover:bg-text/10 flex items-center justify-center transition-colors duration-300">
            <svg class="w-5 h-5 text-text" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </span>
          <div>
            <p class="text-sm font-semibold text-text group-hover:text-text transition-colors duration-300">twitter</p>
            <p class="text-xs text-text-muted/50 mt-0.5">@kaanreal</p>
          </div>
          <span class="ml-auto text-text-muted/20 group-hover:text-text/60 group-hover:translate-x-1 transition-all duration-300 text-sm">→</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 animate-fade-in" style="animation-delay: 0.8s;">
    <a href="#about" class="text-text-muted/40 hover:text-text-muted text-xs tracking-widest uppercase transition-colors duration-300">
      scroll down ↓
    </a>
  </div>
</section>

<script define:vars={{ DISCORD_ID }}>
  const CDN = "https://cdn.discordapp.com";
  const statusColors = { online: "#6BA368", idle: "#D4A574", dnd: "#D4605A", offline: "#8B7080" };
  const gameEmojis = {
    "osu!(stable)": "🎵",
    "osu!lazer": "🎵",
    "osu!": "🎵",
    "Visual Studio Code": "💻",
    "Spotify": "🎶",
  };

  function extractDominantColor(img) {
    const canvas = document.createElement("canvas");
    const size = 16;
    canvas.width = size;
    canvas.height = size;
    const ctx = canvas.getContext("2d");
    ctx.drawImage(img, 0, 0, size, size);
    const data = ctx.getImageData(0, 0, size, size).data;

    let r = 0, g = 0, b = 0, count = 0;
    for (let i = 0; i < data.length; i += 4) {
      const a = data[i + 3];
      if (a < 128) continue;
      r += data[i];
      g += data[i + 1];
      b += data[i + 2];
      count++;
    }
    if (count === 0) return null;
    r = Math.round(r / count);
    g = Math.round(g / count);
    b = Math.round(b / count);
    return `rgb(${r}, ${g}, ${b})`;
  }

  function hexFromRgb(rgb) {
    const match = rgb.match(/\d+/g);
    if (!match) return null;
    return "#" + match.slice(0, 3).map(n => (+n).toString(16).padStart(2, "0")).join("");
  }

  async function loadHero() {
    try {
      const res = await fetch(`https://api.lanyard.rest/v1/users/${DISCORD_ID}`);
      const { data } = await res.json();
      if (!data) return;

      // Avatar + extract color
      const avatarEl = document.getElementById("hero-avatar");
      const nameEl = document.getElementById("hero-name");
      if (avatarEl && data.discord_user.avatar) {
        const ext = data.discord_user.avatar.startsWith("a_") ? "gif" : "png";
        const url = `${CDN}/avatars/${data.discord_user.id}/${data.discord_user.avatar}.${ext}?size=256`;

        // Smooth swap: fade out → swap src → fade in
        avatarEl.style.opacity = "0";
        const preload = new Image();
        preload.onload = () => {
          avatarEl.src = url;
          requestAnimationFrame(() => { avatarEl.style.opacity = "1"; });
        };
        preload.onerror = () => { avatarEl.style.opacity = "1"; };
        preload.src = url;

        // Extract color once image loads
        const img = new Image();
        img.crossOrigin = "anonymous";
        img.src = url;
        img.onload = () => {
          const color = extractDominantColor(img);
          if (color && nameEl) {
            nameEl.style.color = color;
            // Update glow orbs to match
            const glow1 = document.getElementById("hero-glow-1");
            const glow2 = document.getElementById("hero-glow-2");
            if (glow1) glow1.style.backgroundColor = color.replace("rgb", "rgba").replace(")", ", 0.15)");
            if (glow2) glow2.style.backgroundColor = color.replace("rgb", "rgba").replace(")", ", 0.10)");
            // Update avatar shadow
            avatarEl.style.boxShadow = `0 0 40px ${color.replace("rgb", "rgba").replace(")", ", 0.25)")}`;
          }
        };
      }

      // Status dot
      const dot = document.getElementById("hero-status");
      if (dot) {
        dot.style.backgroundColor = statusColors[data.discord_status] || statusColors.offline;
        dot.classList.remove("hidden");
      }

      // Activity
      const activity = data.activities?.find(a => a.type === 0);
      const pill = document.getElementById("hero-activity");
      const actEmoji = document.getElementById("hero-activity-emoji");
      const actName = document.getElementById("hero-activity-name");
      const actDetail = document.getElementById("hero-activity-detail");

      if (activity && pill) {
        pill.classList.remove("hidden");
        if (actEmoji) actEmoji.textContent = gameEmojis[activity.name] || "🎮";
        if (actName) actName.textContent = activity.name;
        if (actDetail) {
          const parts = [activity.details, activity.state].filter(Boolean);
          actDetail.textContent = parts.join(" · ");
        }
      }
    } catch (e) {
      console.error("Lanyard fetch failed:", e);
    }
  }

  loadHero();
</script>

<script>
  const lines = [
    "developer",
    "desktop app builder",
    "open source enthusiast",
    "osu!mania player",
  ];

  const el = document.getElementById("typing-text")!;
  let lineIdx = 0;
  let charIdx = 0;
  let deleting = false;

  function tick() {
    const current = lines[lineIdx];

    if (!deleting) {
      el.textContent = current.slice(0, charIdx + 1);
      charIdx++;
      if (charIdx === current.length) {
        setTimeout(() => { deleting = true; tick(); }, 2000);
        return;
      }
      setTimeout(tick, 80 + Math.random() * 40);
    } else {
      el.textContent = current.slice(0, charIdx - 1);
      charIdx--;
      if (charIdx === 0) {
        deleting = false;
        lineIdx = (lineIdx + 1) % lines.length;
        setTimeout(tick, 400);
        return;
      }
      setTimeout(tick, 40);
    }
  }

  tick();
</script>

<script>
  const btn = document.getElementById("contact-btn");
  const modal = document.getElementById("contact-modal");
  const panel = document.getElementById("contact-panel");
  const closeBtn = document.getElementById("contact-close");
  const overlay = document.getElementById("contact-overlay");

  function openModal() {
    modal?.classList.remove("opacity-0", "pointer-events-none");
    modal?.classList.add("opacity-100", "pointer-events-auto");
    panel?.classList.remove("scale-90");
    panel?.classList.add("scale-100");
  }

  function closeModal() {
    modal?.classList.add("opacity-0", "pointer-events-none");
    modal?.classList.remove("opacity-100", "pointer-events-auto");
    panel?.classList.add("scale-90");
    panel?.classList.remove("scale-100");
  }

  btn?.addEventListener("click", openModal);
  closeBtn?.addEventListener("click", closeModal);
  overlay?.addEventListener("click", closeModal);
</script>
