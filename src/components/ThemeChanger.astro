---
const themes = [
  { id: "peach", color: "#D4605A", bg: "#FFF2ED" },
  { id: "lavender", color: "#9B72CF", bg: "#F3EEFF" },
  { id: "mint", color: "#3DAA82", bg: "#EEFAF5" },
  { id: "rose", color: "#D4567A", bg: "#FFF0F3" },
  { id: "ocean", color: "#4A90D4", bg: "#EEF5FF" },
  { id: "sunset", color: "#D48A3C", bg: "#FFF5EE" },
];
---

<div id="theme-wrap" class="fixed bottom-6 left-6 z-50">
  <!-- Trigger -->
  <button
    id="theme-btn"
    class="w-9 h-9 rounded-full border border-border/60 bg-bg-card/70 backdrop-blur-xl flex items-center justify-center cursor-pointer hover:scale-110 hover:border-border hover:shadow-lg transition-all duration-300 group"
  >
    <svg id="theme-icon-sun" class="w-4 h-4 text-text-muted group-hover:text-brand transition-colors duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="3"/>
      <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
    </svg>
    <svg id="theme-icon-moon" class="w-4 h-4 text-text-muted group-hover:text-brand transition-colors duration-300 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
  </button>

  <!-- Panel -->
  <div
    id="theme-panel"
    class="absolute bottom-14 left-0 opacity-0 scale-95 translate-y-2 pointer-events-none transition-all duration-300 ease-out origin-bottom-left"
  >
    <div class="bg-bg-card/95 backdrop-blur-2xl border border-border rounded-2xl p-5 shadow-[0_20px_60px_rgba(0,0,0,0.12)] min-w-[220px]">
      <!-- Dark mode toggle -->
      <div class="flex items-center justify-between mb-4 pb-3 border-b border-border/50">
        <span class="text-xs font-mono text-text-muted/50 tracking-wider">dark mode</span>
        <button
          id="dark-toggle"
          class="relative w-10 h-5 rounded-full bg-border/50 cursor-pointer transition-colors duration-300 hover:bg-border"
        >
          <span id="dark-dot" class="absolute top-0.5 left-0.5 w-4 h-4 rounded-full bg-text-muted/40 transition-all duration-300"></span>
        </button>
      </div>

      <!-- Theme swatches -->
      <p class="text-[10px] font-mono text-text-muted/40 tracking-widest uppercase mb-3">colors</p>
      <div class="grid grid-cols-6 gap-2">
        {themes.map((t) => (
          <button
            data-theme-set={t.id}
            class="theme-swatch relative w-8 h-8 rounded-full cursor-pointer transition-all duration-300 hover:scale-110 mx-auto"
            style={`background: linear-gradient(135deg, ${t.bg} 50%, ${t.color} 50%); border: 2px solid transparent;`}
            title={t.id}
          >
          </button>
        ))}
      </div>
    </div>
  </div>
</div>

<script>
  const themes = ["peach", "lavender", "mint", "rose", "ocean", "sunset"];
  const btn = document.getElementById("theme-btn");
  const panel = document.getElementById("theme-panel");
  const swatches = document.querySelectorAll("[data-theme-set]");
  const darkToggle = document.getElementById("dark-toggle");
  const darkDot = document.getElementById("dark-dot");
  const sunIcon = document.getElementById("theme-icon-sun");
  const moonIcon = document.getElementById("theme-icon-moon");
  let open = false;

  function transitionTheme() {
    document.documentElement.classList.add("theme-transition");
    setTimeout(() => document.documentElement.classList.remove("theme-transition"), 600);
  }

  function applyTheme(id: string) {
    transitionTheme();
    if (id === "peach") {
      document.documentElement.removeAttribute("data-theme");
    } else {
      document.documentElement.setAttribute("data-theme", id);
    }
    localStorage.setItem("kaan-theme", id);
    updateSwatches(id);
  }

  function setDark(on: boolean) {
    transitionTheme();
    if (on) {
      document.documentElement.setAttribute("data-mode", "dark");
      darkDot.style.left = "22px";
      darkDot.style.background = "var(--color-brand)";
      darkToggle!.style.background = "var(--color-brand)";
      sunIcon?.classList.add("hidden");
      moonIcon?.classList.remove("hidden");
    } else {
      document.documentElement.removeAttribute("data-mode");
      darkDot.style.left = "2px";
      darkDot.style.background = "";
      darkToggle!.style.background = "";
      sunIcon?.classList.remove("hidden");
      moonIcon?.classList.add("hidden");
    }
    localStorage.setItem("kaan-dark", String(on));
  }

  function updateSwatches(activeId: string) {
    swatches.forEach((s) => {
      const el = s as HTMLElement;
      const isActive = el.dataset.themeSet === activeId;
      el.style.transform = isActive ? "scale(1.2)" : "";
      el.style.boxShadow = isActive ? "0 0 0 2px var(--color-bg), 0 0 0 3.5px var(--color-brand)" : "";
    });
  }

  function togglePanel() {
    open = !open;
    if (open) {
      panel?.classList.remove("opacity-0", "scale-95", "translate-y-2", "pointer-events-none");
      panel?.classList.add("opacity-100", "scale-100", "translate-y-0", "pointer-events-auto");
    } else {
      panel?.classList.add("opacity-0", "scale-95", "translate-y-2", "pointer-events-none");
      panel?.classList.remove("opacity-100", "scale-100", "translate-y-0", "pointer-events-auto");
    }
  }

  btn?.addEventListener("click", (e) => {
    e.stopPropagation();
    togglePanel();
  });

  swatches.forEach((s) => {
    s.addEventListener("click", () => {
      applyTheme((s as HTMLElement).dataset.themeSet || "peach");
    });
  });

  darkToggle?.addEventListener("click", (e) => {
    e.stopPropagation();
    const isDark = document.documentElement.getAttribute("data-mode") === "dark";
    setDark(!isDark);
  });

  document.addEventListener("click", (e) => {
    if (open && !document.getElementById("theme-wrap")?.contains(e.target as Node)) {
      open = false;
      panel?.classList.add("opacity-0", "scale-95", "translate-y-2", "pointer-events-none");
      panel?.classList.remove("opacity-100", "scale-100", "translate-y-0", "pointer-events-auto");
    }
  });

  // Load saved
  const savedTheme = localStorage.getItem("kaan-theme");
  const savedDark = localStorage.getItem("kaan-dark") === "true";

  if (savedTheme && themes.includes(savedTheme)) {
    applyTheme(savedTheme);
  }
  if (savedDark) {
    setDark(true);
  }
</script>
