---
import Base from "@/layouts/Base.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  current: string;
}

const { title, description, current } = Astro.props;
---

<Base title={title} description={description}>
  <Nav current={current} />
  <main class="pt-24 pb-8 px-6">
    <div class="max-w-3xl mx-auto">
      <!-- Back -->
      <a href="/" class="inline-flex items-center gap-1.5 text-xs font-mono text-text-muted/50 hover:text-brand transition-colors duration-300 mb-8">
        ← back
      </a>

      <!-- Header -->
      <div class="mb-12">
        <h1 class="text-3xl sm:text-4xl font-heading font-bold text-text mb-3">
          {title}
        </h1>
        {description && (
          <p class="text-text-muted text-sm leading-relaxed max-w-xl">
            {description}
          </p>
        )}
      </div>

      <slot />
    </div>
  </main>
  <Footer />
</Base>
