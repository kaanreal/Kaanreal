---
import "../styles/global.css";
import { site } from "@/data/site";
import ThemeChanger from "@/components/ThemeChanger.astro";

interface Props {
  title?: string;
  description?: string;
}

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");

const {
  title = site.title,
  description = site.description,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FFF2ED" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${BASE}/images/banner.png`} />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${BASE}/images/banner.png`} />

    <link rel="icon" type="image/svg+xml" href={`${BASE}/favicon.svg`} />
    <link rel="preload" as="image" href={`${BASE}/images/icon.png`} />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <title>{title}</title>

    <script is:inline>
      const t = localStorage.getItem("kaan-theme");
      if (t && t !== "peach") document.documentElement.setAttribute("data-theme", t);
    </script>
  </head>
  <body class="min-h-screen bg-bg text-text antialiased">
    <slot />
    <ThemeChanger />
    <script
      src="https://cdn.buymeacoffee.com/button.js"
      data-name="kaandev"
      data-color="#FFDD00"
      data-text="Buy me a coffee"
      data-size="small"
      data-position="Right"
      async
    ></script>
  </body>
</html>
