---
import Base from "@/layouts/Base.astro";
import Nav from "@/components/Nav.astro";
import Hero from "@/components/Hero.astro";
import Footer from "@/components/Footer.astro";

const USERNAME = "Kaanreal";
const LANG_COLORS: Record<string, string> = {
  JavaScript: "#f1e05a", TypeScript: "#3178c6", Python: "#3572A5",
  Java: "#b07219", "C++": "#f34b7d", C: "#555555", "C#": "#178600",
  HTML: "#e34c26", CSS: "#563d7c", Rust: "#dea584", Go: "#00ADD8",
  Ruby: "#701516", Swift: "#F05138", Kotlin: "#A97BFF", Dart: "#00B4AB",
  Shell: "#89e051", Lua: "#000080", Zig: "#ec915c", Nix: "#7e7eff",
  "Objective-C": "#438eff", PHP: "#4F5D95", R: "#198CE7",
};

let repos: any[] = [];
try {
  const res = await fetch(`https://api.github.com/users/${USERNAME}/repos?sort=updated&per_page=100`);
  const data = await res.json();
  if (Array.isArray(data)) {
    repos = data
      .filter((r: any) => !r.fork && r.name.toLowerCase() !== "kaanreal")
      .slice(0, 4)
      .map((r: any) => ({ ...r, langColor: LANG_COLORS[r.language] || "#8b8b8b" }));
  }
} catch (e) {
  console.error("Failed to fetch repos:", e);
}
---

<Base>
  <Nav current="home" />
  <Hero />

  <!-- Developing preview -->
  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <div class="flex items-center gap-4 mb-8">
        <a href="/developing" class="text-xs font-mono tracking-widest uppercase text-brand hover:text-brand/80 transition-colors duration-300">
          developing
        </a>
        <span class="h-px flex-1 bg-border"></span>
        <a
          href="/developing"
          class="text-[11px] font-mono text-text-muted/50 hover:text-brand transition-colors duration-300"
        >
          see all ↗
        </a>
      </div>

      <div class="grid sm:grid-cols-2 gap-3" id="dev-preview-repos">
        {repos.map((repo) => (
          <a href={repo.html_url} target="_blank" rel="noopener noreferrer"
             class="group block bg-bg-card border border-border rounded-xl p-4 card-hover">
            <div class="flex items-start justify-between mb-2">
              <h3 class="text-sm font-semibold text-text group-hover:text-brand transition-colors duration-300 truncate">
                {repo.name}
              </h3>
              <span class="text-text-muted/30 group-hover:text-brand text-xs transition-colors duration-300 flex-shrink-0 ml-2">↗</span>
            </div>
            <p class="text-xs text-text-muted leading-relaxed mb-3 line-clamp-2">
              {repo.description || "No description"}
            </p>
            <div class="flex items-center gap-3 text-[11px] text-text-muted/70">
              {repo.language && (
                <span class="flex items-center gap-1.5">
                  <span class="w-2 h-2 rounded-full" style={`background-color: ${repo.langColor || "#8b8b8b"}`}></span>
                  {repo.language}
                </span>
              )}
              {repo.stargazers_count > 0 && <span>★ {repo.stargazers_count}</span>}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
