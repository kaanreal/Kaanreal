---
import Category from "@/layouts/Category.astro";
---

<Category
  title="osu!mania"
  description="The rhythm game I spend way too much time on."
  current="osu"
>
  <!-- Story -->
  <div class="mb-10 bg-bg-card border border-dashed border-border rounded-xl px-5 py-4 max-w-lg mx-auto">
    <p class="text-sm text-text-muted leading-relaxed text-center">
     Words alone can't describe how much i love vsrg games.
    </p>
  </div>

  <!-- Link to osu portfolio -->
  <a
    href="https://kaanreal.github.io/Portfolio/"
    target="_blank"
    rel="noopener noreferrer"
    class="group block bg-bg-card border border-border rounded-xl p-6 text-center card-hover"
  >
    <p class="text-3xl mb-3">🎹</p>
    <p class="font-heading font-semibold text-text group-hover:text-brand transition-colors duration-300 mb-1">
      osu! portfolio
    </p>
    <p class="text-xs text-text-muted">
       ↗
    </p>
  </a>
</Category>
