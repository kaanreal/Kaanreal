---

<Category
  title="socials"
  description=" everywhere you can find me."
  current="socials"
>
  <!-- Story -->
  <div class="mb-10 bg-bg-card border border-dashed border-border rounded-xl px-5 py-4 max-w-lg mx-auto">
    <p class="text-sm text-text-muted leading-relaxed text-center">
      i'm mostly on <span class="text-text font-medium">discord</span> and <span class="text-text font-medium">twitter</span>. i don't post much but i'm always around. dm me anytime 🤍
    </p>
  </div>

  <!-- Socials grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-xl mx-auto">
    {socials.map((s) => (
      <a
        href={s.url}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-4 bg-bg-card border border-border/50 rounded-2xl px-5 py-4 card-hover transition-all duration-300 hover:border-border"
      >
        <span
          class="w-11 h-11 rounded-xl flex items-center justify-center transition-colors duration-300"
          style={`background-color: ${s.color}15; color: ${s.color}`}
        >
          <span set:html={s.icon} />
        </span>
        <div class="min-w-0">
          <p class="text-sm font-semibold text-text group-hover:text-brand transition-colors duration-300 truncate">{s.name}</p>
          <p class="text-xs text-text-muted/50 truncate">{s.handle}</p>
        </div>
        <span class="ml-auto text-text-muted/15 group-hover:text-brand/50 group-hover:translate-x-1 transition-all duration-300 text-sm flex-shrink-0">→</span>
      </a>
    ))}
  </div>
</Category>
